# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App URL (for Stripe redirects, emails, auth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe Configuration
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
# Stripe price IDs — create Starter (£49/mo) and Growth (£79/mo) products in Stripe Dashboard
# TODO: Replace with real price IDs from Stripe
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_starter_49_xxx
NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID=price_growth_79_xxx
# Server-side fallbacks (optional if NEXT_PUBLIC_* are set)
STRIPE_STARTER_PRICE_ID=price_starter_49_xxx
STRIPE_GROWTH_PRICE_ID=price_growth_79_xxx
# Legacy single-price env (deprecated — use plan-specific IDs above)
# STRIPE_PRICE_ID=price_xxx

# Resend Email (platform default - gyms can override in Settings)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
# Optional: default from address (e.g. noreply@yourdomain.com)
# Used by campaigns and intervention engine
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# Support contact form
SUPPORT_EMAIL=your-support@example.com

# Cron Jobs (required for Vercel cron - generate with: openssl rand -hex 32)
CRON_SECRET=your-random-secret-min-16-chars

# Twilio SMS (optional - platform default; gyms can override in Settings)
# TWILIO_ACCOUNT_SID=ACxxx
# TWILIO_AUTH_TOKEN=xxx
# TWILIO_PHONE_NUMBER=+441234567890

# Supabase Auth: For verification/password reset from your domain,
# configure custom SMTP in Supabase → Project Settings → Authentication.
# See docs/SUPABASE_EMAIL_CONFIG.md